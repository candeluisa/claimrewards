# Copy this file to .env (already gitignored) and fill with YOUR values.
# NEVER commit .env. NEVER paste these values into chat, PRs, or screenshots.

# Private key of the wallet that will deploy + pay gas.
# Must hold Monad testnet MON — grab some from https://faucet.monad.xyz
PRIVATE_KEY=0xYourTestnetOnlyPrivateKeyHere

# Address that receives the 5% protocol fee on every confirmDelivery.
# Usually the same as the deployer for demo, or a separate wallet.
FEE_COLLECTOR=0xYourFeeCollectorAddress
